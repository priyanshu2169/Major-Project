<%- layout("/layouts/boilerplate") %>
<script>
    const Map_api="<%=process.env.Map_API %>";
    const location_for_geo="<%=listings.location %>";
</script>
<body>
    <div class="col-8 offset-2">
    <h3><%= listings.title %></h3>
    </div>
    <div class="row">
        <div class="col-4 offset-2">

        
   <div class="card listing-card">
            <img src="<%=listings.image.url %>" class="card-img-top show-img" style="height: 20rem; width: 40rem;">
              <div class="card-img-overlay"></div>
                <div class="card-body">
                    <p class="card-text"><i>Owned by <%=listings.owner.username %></i></p>
                        
                    <p class="card-text"><%= listings.description %></p> 
                   <p class="card-text">&#8377;<%= listings.price.toLocaleString("en-IN") %>/night 
                <i class="taxes">&nbsp; &nbsp; +18% GST</i>
                </p>
                            
                    <p class="card-text"><%= listings.location %></p>
                    <p class="card-text"><%= listings.country %></p>
                
                </div>
            </div>
</div>
   </div>
            
<% if(currentUser && listings.owner._id.equals(currentUser._id)){ %>
    <div class="col">
        <form method="GET" action="/listings/<%=listings._id %>/edit">
        <button class="btn btn-dark">Edit this listing</button>
    </form>
    <form method="POST" action="/listings/<%=listings._id %>?_method=DELETE">
        <button class="btn btn-dark">Delete this listing</button>
    </form>

    </div>
    <% } %>



    <div class="col-8 offset-2 mb-3">
         <% if(currentUser){ %>
        <h4>Leave a review</h4>
       
        <form action="/listings/<%=listings._id %>/reviews" method="POST" novalidate class="needs-validation">
        <!-- <div class="mb-3 mt-2"> 
            <lable for="rating" class="form-label">Rating</lable>
            <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range"/>
        </div> -->
<div class="mb-3 mt-2">
    <lable for="rating" class="form-label">Rating</lable>
  <fieldset class="starability-slot">
 
  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
  <input type="radio" id="first-rate1" name="review[rating]" value="1" />
  <label for="first-rate1" title="Terrible">1 star</label>
  <input type="radio" id="first-rate2" name="review[rating]" value="2" />
  <label for="first-rate2" title="Not good">2 stars</label>
  <input type="radio" id="first-rate3" name="review[rating]" value="3" />
  <label for="first-rate3" title="Average">3 stars</label>
  <input type="radio" id="first-rate4" name="review[rating]" value="4" />
  <label for="first-rate4" title="Very good">4 stars</label>
  <input type="radio" id="first-rate5" name="review[rating]" value="5" />
  <label for="first-rate5" title="Amazing">5 stars</label>
  </fieldset>
</div>
        <div class="mb-3 mt-2">
            <lable for="comment" class="form-label">Comment</lable>
            <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
            <div class="invalid-feedback">
                Please add a comment
            </div>
        </div>
        <button class="btn btn-outline-dark">Submit</button>
        </form>

       
        <% } %>
        <hr>
        <% if(currentUser){ %>
        <h4><b>All Reviews</b></h4>
        
     <div class="row">
      <%  for(Review of listings.reviews ){%>
        <div class="card col-5 mb-3 ms-3">
            <div class="card-body">
                <h5 class="card-title">@<%=Review.author.username %></h5>
                <p class="card-text"><%=Review.comment %></p>
                
                <p class="starability-result card-text" data-rating="<%=Review.rating %>">
    Rated: 3 stars
  </p>
            </div><br>
            <form action="/listings/<%=listings._id%>/reviews/<%=Review._id%>?_method=DELETE" method="POST">
                <button class="btn btn-sm btn-dark mb-2">Delete</button>
            </form>
        </div>
      <%  }%>
      </div> 

      <% } %>
      
      
  
    </div>
    <div class="col-8 offset-2 mb-3">
        <h3>Where you will be</h3>
        <div id="map"></div>
      </div> 


   
</body>
<script src="/JS/map.js"></script>
