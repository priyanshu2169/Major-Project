<%- layout("/layouts/boilerplate") %>

<body>
    <br><br>
    <h4>Popular homes &nbsp;<i class="fa-solid fa-arrow-right-long" style="border-radius: 50%; background-color: gray; font-size: 1rem; color: black;"></i></h4>
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">

       <% for(let items of searchItems){ %>
        <a href="/listings/<%=items._id %>" class="listing-link">
            <div class="card listing-card">
            <img src="<%=items.image.url %>" class="card-img-top" style="height: 20rem;">
              <div class="card-img-overlay"></div>
                <div class="card-body">
                    <p class="card-text">
                        <b><%= items.title %></b><br>
                    &#8377;<%= items.price.toLocaleString("en-IN") %>/night
                    <i class="taxes">&nbsp; &nbsp; +18% GST</i>
                    </p>
                </div>
            </div>
        </a>    
            
       <% } %>





</div>

</body>